{
  "name": "erpdog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @erpdog/web --filter @erpdog/api --filter @erpdog/worker dev",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "corepack pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "corepack pnpm audit --audit-level moderate",
    "review:check": "corepack pnpm format:check && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm build && corepack pnpm audit --audit-level moderate",
    "test:e2e": "tsx --tsconfig apps/api/tsconfig.json apps/api/test/business-flow.e2e.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx prisma/seed-demo.ts",
    "infra:up": "docker compose up -d postgres redis minio",
    "infra:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
