NODE_ENV=production
APP_URL=https://erp.example.com
API_URL=https://api.erp.example.com
NEXT_PUBLIC_API_URL=https://api.erp.example.com/api/v1

DATABASE_URL=postgresql://erpdog:change-me@postgres:5432/erpdog?schema=public
REDIS_URL=redis://redis:6379

JWT_SECRET=generate-a-strong-production-secret
JWT_ACCESS_TTL=8h

S3_ENDPOINT=https://s3.example.com
S3_REGION=auto
S3_BUCKET=erpdog
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_FORCE_PATH_STYLE=true

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=generate-a-strong-admin-password
ADMIN_NAME=System Admin
