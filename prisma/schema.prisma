generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CustomerStatus {
  ACTIVE
  PAUSED
  TERMINATED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  TERMINATED
}

enum TaxpayerType {
  SMALL_SCALE
  GENERAL
  OVERSEAS
}

enum ChargeItemKind {
  FIXED
  VARIABLE
  DISCOUNT
  WAIVER
  MANUAL
}

enum ChargeSourceType {
  CONTRACT
  EXTRA_CHARGE
  ADJUSTMENT
  MANUAL
}

enum ExtraChargeKind {
  VALUE_ADDED
  ADVANCE_PAYMENT
}

enum ExtraChargeStatus {
  DRAFT
  BILLING_INCLUDED
  CANCELLED
}

enum BillStatus {
  DRAFT
  PENDING_APPROVAL
  PENDING_SETTLEMENT
  INVOICED
  RECEIVED
  INTERNAL_REVIEW
  FINANCE_REVIEW
  CUSTOMER_PENDING
  CUSTOMER_CONFIRMED
  CLOSED
  VOIDED
  ADJUSTED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  VOIDED
}

enum ReceiptStatus {
  REGISTERED
  REVERSED
}

enum PayableStatus {
  UNPAID
  CONFIRMED
  PARTIALLY_PAID
  PAID
  VOIDED
}

enum PaymentRecipientPlatform {
  PRIVATE_BANK
  CORPORATE_BANK
  WECHAT
  ALIPAY
}

enum PaymentRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  PARTIALLY_PAID
  PAID
}

enum PaymentStatus {
  REGISTERED
  REVERSED
}

enum PeriodClosingStatus {
  OPEN
  CLOSED
  REOPENED
}

model Organization {
  id         String   @id @default(uuid())
  name       String
  code       String   @unique
  isActive   Boolean  @default(true) @map("is_active")
  isPlatform Boolean  @default(false) @map("is_platform")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  users                  User[]
  roles                  Role[]
  auditLogs              AuditLog[]
  customers              Customer[]
  signingEntities        SigningEntity[]
  contracts              Contract[]
  chargeRuleTemplates    ChargeRuleTemplate[]
  extraChargeCategories  ExtraChargeCategory[]
  billingPeriods         BillingPeriod[]
  bills                  Bill[]
  invoices               Invoice[]
  receipts               Receipt[]
  costCategories         CostCategory[]
  costEntries            CostEntry[]
  payables               Payable[]
  paymentRecipients      PaymentRecipient[]
  paymentRequests        PaymentRequest[]
  payments               Payment[]
  periodClosings         PeriodClosing[]
  attachments            Attachment[]
  monthlyCustomerMetrics MonthlyCustomerMetric[]

  @@map("organizations")
}

model User {
  id           String    @id @default(uuid())
  orgId        String    @map("org_id")
  email        String    @unique
  phone        String?   @unique
  name         String
  passwordHash String?   @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  feishuUserId String?   @map("feishu_user_id")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Restrict)
  userRoles      UserRole[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]      @relation("AuditActor")
  customerOwners CustomerOwner[]

  @@index([orgId])
  @@index([feishuUserId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  code        String
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Restrict)
  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([orgId, code])
  @@index([orgId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  before      Json?
  after       Json?
  reason      String?
  ip          String?
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  actor User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("audit_logs")
}

model DomainEvent {
  id            String   @id @default(uuid())
  orgId         String?  @map("org_id")
  topic         String
  aggregateType String?  @map("aggregate_type")
  aggregateId   String?  @map("aggregate_id")
  payload       Json
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([orgId, createdAt])
  @@index([topic, createdAt])
  @@index([aggregateType, aggregateId])
  @@map("domain_events")
}

model OutboxEvent {
  id            String    @id @default(uuid())
  orgId         String?   @map("org_id")
  topic         String
  aggregateType String?   @map("aggregate_type")
  aggregateId   String?   @map("aggregate_id")
  payload       Json
  status        String    @default("pending")
  attempts      Int       @default(0)
  nextRunAt     DateTime  @default(now()) @map("next_run_at")
  lockedAt      DateTime? @map("locked_at")
  processedAt   DateTime? @map("processed_at")
  error         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([status, nextRunAt])
  @@index([orgId, createdAt])
  @@index([topic, createdAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

model Customer {
  id        String         @id @default(uuid())
  orgId     String         @map("org_id")
  code      String
  name      String
  fullName  String?        @map("full_name")
  status    CustomerStatus @default(ACTIVE)
  industry  String?
  source    String?
  notes     String?
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  org             Organization             @relation(fields: [orgId], references: [id], onDelete: Restrict)
  contacts        CustomerContact[]
  billingProfiles CustomerBillingProfile[]
  owners          CustomerOwner[]
  contracts       Contract[]
  extraCharges    ExtraCharge[]
  bills           Bill[]
  costEntries     CostEntry[]
  payables        Payable[]
  paymentRequests PaymentRequest[]
  monthlyMetrics  MonthlyCustomerMetric[]

  @@unique([orgId, code])
  @@index([orgId, status])
  @@index([name])
  @@index([fullName])
  @@map("customers")
}

model CustomerContact {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  name       String
  title      String?
  phone      String?
  email      String?
  address    String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_contacts")
}

model CustomerBillingProfile {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  title       String
  taxNumber   String?  @map("tax_number")
  bankName    String?  @map("bank_name")
  bankAccount String?  @map("bank_account")
  address     String?
  phone       String?
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_billing_profiles")
}

model CustomerOwner {
  customerId String   @map("customer_id")
  userId     String   @map("user_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([customerId, userId])
  @@index([userId])
  @@map("customer_owners")
}

model SigningEntity {
  id                  String       @id @default(uuid())
  orgId               String       @map("org_id")
  code                String
  shortName           String       @map("short_name")
  fullName            String       @map("full_name")
  legalRepresentative String       @map("legal_representative")
  taxpayerType        TaxpayerType @map("taxpayer_type")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  contracts Contract[]

  @@unique([orgId, code])
  @@unique([orgId, fullName])
  @@index([orgId])
  @@index([shortName])
  @@map("signing_entities")
}

model Contract {
  id                 String         @id @default(uuid())
  orgId              String         @map("org_id")
  customerId         String         @map("customer_id")
  signingEntityId    String?        @map("signing_entity_id")
  code               String
  name               String
  status             ContractStatus @default(DRAFT)
  startDate          DateTime       @map("start_date")
  endDate            DateTime?      @map("end_date")
  billingDay         Int            @default(1) @map("billing_day")
  currency           String         @default("CNY")
  notes              String?
  baseFee            Decimal?       @map("base_fee") @db.Decimal(18, 2)
  incentiveUnitPrice Decimal?       @map("incentive_unit_price") @db.Decimal(18, 2)
  serviceFeeRate     Decimal?       @map("service_fee_rate") @db.Decimal(8, 4)
  tierMode           String?        @map("tier_mode")
  tierRules          Json?          @map("tier_rules")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  org           Organization         @relation(fields: [orgId], references: [id], onDelete: Restrict)
  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  signingEntity SigningEntity?       @relation(fields: [signingEntityId], references: [id], onDelete: Restrict)
  chargeItems   ContractChargeItem[]
  extraCharges  ExtraCharge[]
  bills         Bill[]
  attachments   Attachment[]

  @@unique([orgId, code])
  @@index([orgId, status])
  @@index([customerId, status])
  @@index([signingEntityId])
  @@map("contracts")
}

model ContractChargeItem {
  id          String         @id @default(uuid())
  contractId  String         @map("contract_id")
  name        String
  kind        ChargeItemKind @default(FIXED)
  amount      Decimal        @db.Decimal(18, 2)
  quantity    Decimal        @default(1) @db.Decimal(18, 4)
  unit        String?
  description String?
  startsAt    DateTime?      @map("starts_at")
  endsAt      DateTime?      @map("ends_at")
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  contract  Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  billItems BillItem[]

  @@index([contractId, isActive])
  @@map("contract_charge_items")
}

model ChargeRuleTemplate {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  code        String
  name        String
  description String?
  payload     Json
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@unique([orgId, code])
  @@index([orgId, isActive])
  @@map("charge_rule_templates")
}

model ExtraChargeCategory {
  id        String          @id @default(uuid())
  orgId     String          @map("org_id")
  code      String
  name      String
  kind      ExtraChargeKind
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Restrict)
  extraCharges ExtraCharge[]

  @@unique([orgId, code])
  @@index([orgId, kind])
  @@map("extra_charge_categories")
}

model ExtraCharge {
  id           String            @id @default(uuid())
  orgId        String            @map("org_id")
  customerId   String            @map("customer_id")
  contractId   String?           @map("contract_id")
  categoryId   String?           @map("category_id")
  kind         ExtraChargeKind
  name         String
  amount       Decimal           @db.Decimal(18, 2)
  incurredDate DateTime          @map("incurred_date")
  periodMonth  String            @map("period_month")
  status       ExtraChargeStatus @default(DRAFT)
  description  String?
  createdById  String?           @map("created_by_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  customer  Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  contract  Contract?            @relation(fields: [contractId], references: [id], onDelete: SetNull)
  category  ExtraChargeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  billItems BillItem[]

  @@index([orgId, periodMonth])
  @@index([customerId, periodMonth])
  @@index([status, periodMonth])
  @@map("extra_charges")
}

model BillingPeriod {
  id          String              @id @default(uuid())
  orgId       String              @map("org_id")
  periodMonth String              @map("period_month")
  startsOn    DateTime            @map("starts_on")
  endsOn      DateTime            @map("ends_on")
  status      PeriodClosingStatus @default(OPEN)
  closedAt    DateTime?           @map("closed_at")
  reopenedAt  DateTime?           @map("reopened_at")
  reason      String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@unique([orgId, periodMonth])
  @@index([orgId, status])
  @@map("billing_periods")
}

model Bill {
  id                    String     @id @default(uuid())
  orgId                 String     @map("org_id")
  customerId            String     @map("customer_id")
  contractId            String?    @map("contract_id")
  billNo                String     @map("bill_no")
  periodMonth           String     @map("period_month")
  status                BillStatus @default(DRAFT)
  currency              String     @default("CNY")
  subtotal              Decimal    @default(0) @db.Decimal(18, 2)
  adjustmentTotal       Decimal    @default(0) @map("adjustment_total") @db.Decimal(18, 2)
  totalAmount           Decimal    @default(0) @map("total_amount") @db.Decimal(18, 2)
  dueDate               DateTime?  @map("due_date")
  approvalRequestedAt   DateTime?  @map("approval_requested_at")
  approvedAt            DateTime?  @map("approved_at")
  approvedById          String?    @map("approved_by_id")
  confirmedAt           DateTime?  @map("confirmed_at")
  confirmedBy           String?    @map("confirmed_by")
  confirmationNote      String?    @map("confirmation_note")
  evidenceAttachmentIds Json?      @map("evidence_attachment_ids")
  invoiceAttachmentIds  Json?      @map("invoice_attachment_ids")
  receiptAttachmentIds  Json?      @map("receipt_attachment_ids")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  org                Organization        @relation(fields: [orgId], references: [id], onDelete: Restrict)
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  contract           Contract?           @relation(fields: [contractId], references: [id], onDelete: SetNull)
  items              BillItem[]
  settlements        BillSettlement[]
  confirmations      BillConfirmation[]
  adjustments        BillAdjustment[]
  statusEvents       BillStatusEvent[]
  invoiceAllocations InvoiceAllocation[]
  receiptAllocations ReceiptAllocation[]
  payables           Payable[]

  @@unique([orgId, billNo])
  @@unique([orgId, contractId, periodMonth])
  @@index([orgId, periodMonth])
  @@index([customerId, periodMonth])
  @@index([status, periodMonth])
  @@map("bills")
}

model BillItem {
  id                   String           @id @default(uuid())
  billId               String           @map("bill_id")
  contractChargeItemId String?          @map("contract_charge_item_id")
  extraChargeId        String?          @map("extra_charge_id")
  adjustmentId         String?          @map("adjustment_id")
  sourceType           ChargeSourceType @map("source_type")
  name                 String
  description          String?
  amount               Decimal          @db.Decimal(18, 2)
  quantity             Decimal          @default(1) @db.Decimal(18, 4)
  lineTotal            Decimal          @map("line_total") @db.Decimal(18, 2)
  occurredDate         DateTime?        @map("occurred_date")
  createdAt            DateTime         @default(now()) @map("created_at")

  bill               Bill                @relation(fields: [billId], references: [id], onDelete: Cascade)
  contractChargeItem ContractChargeItem? @relation(fields: [contractChargeItemId], references: [id], onDelete: SetNull)
  extraCharge        ExtraCharge?        @relation(fields: [extraChargeId], references: [id], onDelete: SetNull)

  @@index([billId])
  @@index([extraChargeId])
  @@map("bill_items")
}

model BillSettlement {
  id        String   @id @default(uuid())
  billId    String   @map("bill_id")
  title     String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  bill  Bill                 @relation(fields: [billId], references: [id], onDelete: Cascade)
  items BillSettlementItem[]

  @@index([billId, sortOrder])
  @@map("bill_settlements")
}

model BillSettlementItem {
  id                  String   @id @default(uuid())
  settlementId        String   @map("settlement_id")
  customerContactName String   @map("customer_contact_name")
  projectName         String   @map("project_name")
  periodMonth         String   @map("period_month")
  cooperationModes    Json     @map("cooperation_modes")
  otherModeNote       String?  @map("other_mode_note")
  cooperationFee      Decimal  @map("cooperation_fee") @db.Decimal(18, 2)
  serviceFee          Decimal  @map("service_fee") @db.Decimal(18, 2)
  totalFee            Decimal  @map("total_fee") @db.Decimal(18, 2)
  createdAt           DateTime @default(now()) @map("created_at")

  settlement BillSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@index([periodMonth])
  @@map("bill_settlement_items")
}

model BillConfirmation {
  id                   String   @id @default(uuid())
  billId               String   @map("bill_id")
  confirmedByName      String   @map("confirmed_by_name")
  confirmedAt          DateTime @default(now()) @map("confirmed_at")
  note                 String?
  evidenceAttachmentId String?  @map("evidence_attachment_id")

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@map("bill_confirmations")
}

model BillAdjustment {
  id          String   @id @default(uuid())
  billId      String   @map("bill_id")
  amount      Decimal  @db.Decimal(18, 2)
  reason      String
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@map("bill_adjustments")
}

model BillStatusEvent {
  id          String      @id @default(uuid())
  billId      String      @map("bill_id")
  fromStatus  BillStatus? @map("from_status")
  toStatus    BillStatus  @map("to_status")
  note        String?
  actorUserId String?     @map("actor_user_id")
  createdAt   DateTime    @default(now()) @map("created_at")

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId, createdAt])
  @@map("bill_status_events")
}

model Invoice {
  id               String        @id @default(uuid())
  orgId            String        @map("org_id")
  invoiceNo        String        @map("invoice_no")
  invoiceType      String        @map("invoice_type")
  status           InvoiceStatus @default(ISSUED)
  issueDate        DateTime      @map("issue_date")
  amount           Decimal       @db.Decimal(18, 2)
  taxAmount        Decimal       @default(0) @map("tax_amount") @db.Decimal(18, 2)
  remarks          String?
  fileAttachmentId String?       @map("file_attachment_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Restrict)
  allocations InvoiceAllocation[]

  @@unique([orgId, invoiceNo])
  @@index([orgId, issueDate])
  @@index([status])
  @@map("invoices")
}

model InvoiceAllocation {
  id        String   @id @default(uuid())
  invoiceId String   @map("invoice_id")
  billId    String   @map("bill_id")
  amount    Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([billId])
  @@map("invoice_allocations")
}

model Receipt {
  id           String        @id @default(uuid())
  orgId        String        @map("org_id")
  receiptNo    String?       @map("receipt_no")
  receivedAt   DateTime      @map("received_at")
  amount       Decimal       @db.Decimal(18, 2)
  account      String
  payer        String?
  status       ReceiptStatus @default(REGISTERED)
  remarks      String?
  attachmentId String?       @map("attachment_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Restrict)
  allocations ReceiptAllocation[]

  @@index([orgId, receivedAt])
  @@index([status])
  @@map("receipts")
}

model ReceiptAllocation {
  id        String   @id @default(uuid())
  receiptId String   @map("receipt_id")
  billId    String   @map("bill_id")
  amount    Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now()) @map("created_at")

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Restrict)

  @@index([receiptId])
  @@index([billId])
  @@map("receipt_allocations")
}

model CostCategory {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  code      String
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Restrict)
  costEntries         CostEntry[]
  payables            Payable[]
  paymentRequests     PaymentRequest[]
  paymentRequestItems PaymentRequestItem[]

  @@unique([orgId, code])
  @@index([orgId, isActive])
  @@map("cost_categories")
}

model CostEntry {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  customerId     String   @map("customer_id")
  periodMonth    String   @map("period_month")
  categoryId     String?  @map("category_id")
  amount         Decimal  @db.Decimal(18, 2)
  incurredDate   DateTime @map("incurred_date")
  handlerUserId  String?  @map("handler_user_id")
  description    String?
  attachmentId   String?  @map("attachment_id")
  payableCreated Boolean  @default(false) @map("payable_created")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  org      Organization  @relation(fields: [orgId], references: [id], onDelete: Restrict)
  customer Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  category CostCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  payables Payable[]

  @@index([orgId, periodMonth])
  @@index([customerId, periodMonth])
  @@index([categoryId])
  @@map("cost_entries")
}

model Payable {
  id                 String                   @id @default(uuid())
  orgId              String                   @map("org_id")
  customerId         String?                  @map("customer_id")
  billId             String?                  @map("bill_id")
  costEntryId        String?                  @map("cost_entry_id")
  categoryId         String?                  @map("category_id")
  paymentRecipientId String?                  @map("payment_recipient_id")
  vendorName         String                   @map("vendor_name")
  receiptPlatform    PaymentRecipientPlatform @default(PRIVATE_BANK) @map("receipt_platform")
  receiptAccountName String                   @default("") @map("receipt_account_name")
  receiptAccountNo   String                   @default("") @map("receipt_account_no")
  receiptBankBranch  String?                  @map("receipt_bank_branch")
  periodMonth        String?                  @map("period_month")
  amount             Decimal                  @db.Decimal(18, 2)
  paidAmount         Decimal                  @default(0) @map("paid_amount") @db.Decimal(18, 2)
  status             PayableStatus            @default(UNPAID)
  dueDate            DateTime?                @map("due_date")
  remarks            String?
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Restrict)
  customer            Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  bill                Bill?                @relation(fields: [billId], references: [id], onDelete: SetNull)
  costEntry           CostEntry?           @relation(fields: [costEntryId], references: [id], onDelete: SetNull)
  category            CostCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  paymentRecipient    PaymentRecipient?    @relation(fields: [paymentRecipientId], references: [id], onDelete: SetNull)
  paymentRequestItems PaymentRequestItem[]
  paymentAllocations  PaymentAllocation[]

  @@index([orgId, periodMonth])
  @@index([customerId, periodMonth])
  @@index([billId])
  @@index([paymentRecipientId])
  @@index([status])
  @@map("payables")
}

model PaymentRecipient {
  id          String                   @id @default(uuid())
  orgId       String                   @map("org_id")
  name        String
  platform    PaymentRecipientPlatform
  accountName String                   @map("account_name")
  accountNo   String                   @map("account_no")
  bankBranch  String?                  @map("bank_branch")
  isActive    Boolean                  @default(true) @map("is_active")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  payables Payable[]

  @@index([orgId, isActive])
  @@index([name])
  @@index([accountName])
  @@index([accountNo])
  @@map("payment_recipients")
}

model PaymentRequest {
  id                  String               @id @default(uuid())
  orgId               String               @map("org_id")
  requestNo           String               @map("request_no")
  status              PaymentRequestStatus @default(DRAFT)
  applicantUserId     String?              @map("applicant_user_id")
  supplierName        String               @map("supplier_name")
  customerId          String?              @map("customer_id")
  periodMonth         String?              @map("period_month")
  categoryId          String?              @map("category_id")
  payableId           String?              @map("payable_id")
  totalAmount         Decimal              @default(0) @map("total_amount") @db.Decimal(18, 2)
  requestedAmount     Decimal              @default(0) @map("requested_amount") @db.Decimal(18, 2)
  accountInfo         Json?                @map("account_info")
  reason              String?
  expectedPaymentDate DateTime?            @map("expected_payment_date")
  submittedAt         DateTime?            @map("submitted_at")
  decidedAt           DateTime?            @map("decided_at")
  decidedById         String?              @map("decided_by_id")
  rejectReason        String?              @map("reject_reason")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  org       Organization         @relation(fields: [orgId], references: [id], onDelete: Restrict)
  customer  Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  category  CostCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items     PaymentRequestItem[]
  approvals PaymentApproval[]
  payments  Payment[]

  @@unique([orgId, requestNo])
  @@index([orgId, status])
  @@index([customerId, periodMonth])
  @@map("payment_requests")
}

model PaymentRequestItem {
  id          String   @id @default(uuid())
  requestId   String   @map("request_id")
  payableId   String?  @map("payable_id")
  customerId  String?  @map("customer_id")
  periodMonth String?  @map("period_month")
  categoryId  String?  @map("category_id")
  amount      Decimal  @db.Decimal(18, 2)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  request  PaymentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  payable  Payable?       @relation(fields: [payableId], references: [id], onDelete: SetNull)
  category CostCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([payableId])
  @@map("payment_request_items")
}

model PaymentApproval {
  id             String   @id @default(uuid())
  requestId      String   @map("request_id")
  approverUserId String?  @map("approver_user_id")
  action         String
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")

  request PaymentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
  @@map("payment_approvals")
}

model Payment {
  id           String        @id @default(uuid())
  orgId        String        @map("org_id")
  paymentNo    String        @map("payment_no")
  requestId    String?       @map("request_id")
  paidAt       DateTime      @map("paid_at")
  amount       Decimal       @db.Decimal(18, 2)
  account      String
  payeeName    String        @map("payee_name")
  status       PaymentStatus @default(REGISTERED)
  remarks      String?
  attachmentId String?       @map("attachment_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Restrict)
  request     PaymentRequest?     @relation(fields: [requestId], references: [id], onDelete: SetNull)
  allocations PaymentAllocation[]

  @@unique([orgId, paymentNo])
  @@index([orgId, paidAt])
  @@index([requestId])
  @@map("payments")
}

model PaymentAllocation {
  id        String   @id @default(uuid())
  paymentId String   @map("payment_id")
  payableId String?  @map("payable_id")
  amount    Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now()) @map("created_at")

  payment Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  payable Payable? @relation(fields: [payableId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([payableId])
  @@map("payment_allocations")
}

model PeriodClosing {
  id          String              @id @default(uuid())
  orgId       String              @map("org_id")
  periodMonth String              @map("period_month")
  status      PeriodClosingStatus
  reason      String?
  snapshot    Json?
  actorUserId String?             @map("actor_user_id")
  createdAt   DateTime            @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@index([orgId, periodMonth, createdAt])
  @@map("period_closings")
}

model Attachment {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  ownerType    String?  @map("owner_type")
  ownerId      String?  @map("owner_id")
  fileName     String   @map("file_name")
  contentType  String?  @map("content_type")
  sizeBytes    BigInt?  @map("size_bytes")
  storageKey   String   @map("storage_key")
  url          String?
  uploadedById String?  @map("uploaded_by_id")
  contractId   String?  @map("contract_id")
  createdAt    DateTime @default(now()) @map("created_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  contract Contract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([orgId, ownerType, ownerId])
  @@index([contractId])
  @@map("attachments")
}

model MonthlyCustomerMetric {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  customerId   String   @map("customer_id")
  periodMonth  String   @map("period_month")
  incomeAmount Decimal  @default(0) @map("income_amount") @db.Decimal(18, 2)
  costAmount   Decimal  @default(0) @map("cost_amount") @db.Decimal(18, 2)
  profitAmount Decimal  @default(0) @map("profit_amount") @db.Decimal(18, 2)
  grossMargin  Decimal? @map("gross_margin") @db.Decimal(9, 4)
  updatedAt    DateTime @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([orgId, customerId, periodMonth])
  @@index([orgId, periodMonth])
  @@map("monthly_customer_metrics")
}
